# MongoDB Connection String
# Replace with your actual MongoDB Atlas URL
MONGO_URL=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/depression_predictor?retryWrites=true&w=majority

# YouTube API Key (optional, for video features)
# Get from https://console.cloud.google.com
YOUTUBE_API_KEY=your_youtube_api_key_here

# Used in frontend
VITE_YOUTUBE_API_KEY=your_youtube_api_key_here
